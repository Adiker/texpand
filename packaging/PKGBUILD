# Maintainer: your name <you@example.com>
# PKGBUILD for texpand with Polish diacritics autocorrection.
# Build from a local checkout:   cd packaging && makepkg -si
# (or point source= at your fork's tag tarball)

pkgname=texpand
pkgver=r1
pkgrel=1
pkgdesc="Lightweight Wayland text expander with Polish diacritics autocorrection (evdev/uinput)"
arch=('x86_64' 'aarch64')
url="https://github.com/andresousadotpt/texpand"
license=('MIT')
depends=('glibc')
makedepends=('go' 'git')
optdepends=(
  'hunspell-pl: Polish dictionary for autocorrection'
  'wtype: Unicode output fallback'
  'wl-clipboard: clipboard paste fallback (opt-in)'
)
source=()
sha256sums=()

pkgver() {
  cd "$startdir/.."
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
  cd "$startdir/.."
  export CGO_ENABLED=0
  go build -trimpath \
    -buildmode=pie \
    -mod=readonly \
    -ldflags "-X main.version=$(git describe --tags --always 2>/dev/null || echo git)" \
    -o "$srcdir/texpand" .
}

check() {
  cd "$startdir/.."
  go test ./...
}

package() {
  install -Dm755 "$srcdir/texpand" "$pkgdir/usr/bin/texpand"

  cd "$startdir/.."
  install -Dm644 packaging/texpand.service \
    "$pkgdir/usr/lib/systemd/user/texpand.service"
  install -Dm644 99-uinput.rules \
    "$pkgdir/usr/lib/udev/rules.d/99-texpand-uinput.rules"
  install -Dm644 packaging/texpand-uinput.conf \
    "$pkgdir/usr/lib/modules-load.d/texpand-uinput.conf"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
  install -Dm644 docs/architecture.md "$pkgdir/usr/share/doc/$pkgname/architecture.md"
  install -Dm644 defaults/config.yml "$pkgdir/usr/share/doc/$pkgname/config.example.yml"
}
